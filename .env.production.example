# === REQUIRED ===

# PostgreSQL
POSTGRES_DB=trade
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_strong_password

# Database URL (used by bot and web)
DATABASE_URL=postgresql://postgres:change_this_strong_password@postgres:5432/trade

# Dashboard basic auth
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change_this_strong_password

# === OPTIONAL ===

# Trading mode (paper = safe default, live = real money)
BOT_MODE=paper
LOG_LEVEL=info

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Exchange API (only needed for live trading)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Web port (host port to expose)
WEB_PORT=4000
