# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/trade

# Bot mode (paper or live — live requires manual activation in settings)
BOT_MODE=paper
LOG_LEVEL=info

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Exchange API keys (only required for live trading)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Web dashboard
PORT=4000
NODE_ENV=development
