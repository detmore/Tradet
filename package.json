{
  "name": "trade",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:bot": "pnpm --filter bot dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @trade/db generate",
    "db:migrate": "pnpm --filter @trade/db migrate",
    "db:push": "pnpm --filter @trade/db push",
