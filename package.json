    "bot:dev": "pnpm --filter bot dev",
    "backtest": "pnpm --filter bot tsx scripts/backtest.ts"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sharp", "unrs-resolver", "esbuild", "@swc/core"]
  }
}
